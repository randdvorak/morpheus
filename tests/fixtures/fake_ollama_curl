#!/bin/sh
set -eu

url=
request_path=
for argument in "$@"; do
    case "$argument" in
        @*) request_path=${argument#@} ;;
        http://*|https://*) url=$argument ;;
    esac
done

case "$url" in
    */api/tags)
        printf '%s\n' '{"models":[{"name":"fake-coder:latest"}]}'
        ;;
    */api/chat)
        if [ -z "$request_path" ] ||
            ! /usr/bin/jq -e \
                '.model == "fake-coder:latest" and
                 .stream == false and
                 .format.type == "object" and
                 .format.properties.source.pattern == "^.*morph_app_entry.*$" and
                 .format.properties.source.minLength == 256 and
                 (.messages[0].content | contains("Do not ask follow-up questions")) and
                 (.messages[0].content | contains("MORPHEUS_RENDER_NUKLEAR_WINDOWS")) and
                 (.messages[0].content | contains("ui_label")) and
                 (.messages[0].content | contains("morph_json_parse")) and
                 (.messages[0].content | contains("morph_image_load_url")) and
                 (.messages[0].content | contains("snprintf, vsnprintf")) and
                 (.messages[0].content | contains("versioned, pointer-free format")) and
                 (.messages[1].content | contains("Current candidate.c"))' \
                "$request_path" >/dev/null; then
            echo "invalid Ollama request" >&2
            exit 22
        fi
        if [ "${FAKE_OLLAMA_FENCED:-}" = 1 ]; then
            content='```c
#include "morpheus/app_api.h"
const morph_app_api *morph_app_entry(void) { return 0; }
```
The model returned fenced source.'
        else
            content=$(/usr/bin/jq -cn '{source:"int repaired_by_ollama;\nconst morph_app_api *morph_app_entry(void) { return 0; }\n",summary:"local model updated candidate"}')
        fi
        /usr/bin/jq -cn --arg content "$content" '{message:{role:"assistant",content:$content},done:true}'
        ;;
    *)
        echo "unexpected URL: $url" >&2
        exit 22
        ;;
esac
