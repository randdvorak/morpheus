#!/bin/sh
set -eu

workspace=$1
prompt_path=$2
diagnostics_path=$3
response_path=$4
script_directory=$(/usr/bin/dirname "$0")
ollama_url=${MORPHEUS_OLLAMA_URL:-http://localhost:11434}
ollama_url=${ollama_url%/}
curl_executable=${MORPHEUS_CURL_EXECUTABLE:-/usr/bin/curl}
jq_executable=${MORPHEUS_JQ_EXECUTABLE:-/usr/bin/jq}
model=${MORPHEUS_OLLAMA_MODEL:-}
keep_alive=${MORPHEUS_OLLAMA_KEEP_ALIVE:-10m}
timeout=${MORPHEUS_OLLAMA_TIMEOUT:-600}
system_prompt_path=${MORPHEUS_OLLAMA_SYSTEM_PROMPT:-$script_directory/morpheus-ollama-system-prompt.txt}
model_path=$workspace/model.txt
candidate_path=$workspace/candidate.c
api_path=$workspace/app_api.h
request_path=$workspace/ollama-request.json
raw_response_path=$workspace/ollama-response.json
candidate_temporary=$workspace/candidate.c.ollama.tmp
content_path=$workspace/ollama-content.txt

if [ ! -x "$curl_executable" ] || [ ! -x "$jq_executable" ]; then
    echo "Ollama provider requires executable curl and jq commands" >&2
    exit 127
fi
if [ ! -s "$system_prompt_path" ] || [ ! -s "$api_path" ]; then
    echo "Ollama provider requires a system prompt and app_api.h" >&2
    exit 66
fi

if [ -z "$model" ] && [ -s "$model_path" ]; then
    model=$(/usr/bin/sed -n '1{s/[[:space:]]*$//;p;}' "$model_path")
fi

if [ -z "$model" ]; then
    tags=$(
        "$curl_executable" \
            --silent \
            --show-error \
            --fail \
            --max-time 3 \
            "$ollama_url/api/tags"
    ) || {
        echo "Unable to reach Ollama at $ollama_url. Start it with: ollama serve" >&2
        exit 69
    }
    model=$(printf '%s' "$tags" | "$jq_executable" -er '
        ([.models[] | (.name // .model) | select(type == "string" and (contains(":cloud") | not))][0] //
         [.models[] | (.name // .model)][0] // empty)
    ') || {
        echo "Ollama has no installed models. Install one with: ollama pull <model>" >&2
        exit 69
    }
fi

echo "Using Ollama model: $model"

"$jq_executable" -n \
    --arg model "$model" \
    --arg keep_alive "$keep_alive" \
    --rawfile system_prompt "$system_prompt_path" \
    --rawfile api "$api_path" \
    --rawfile prompt "$prompt_path" \
    --rawfile source "$candidate_path" \
    '{
        model: $model,
        stream: false,
        keep_alive: $keep_alive,
        format: {
            type: "object",
            properties: {
                source: {
                    type: "string",
                    minLength: 256,
                    pattern: "^.*morph_app_entry.*$"
                },
                summary: {type: "string"}
            },
            required: ["source", "summary"],
            additionalProperties: false
        },
        options: {temperature: 0},
        messages: [
            {
                role: "system",
                content: ($system_prompt + $api)
            },
            {
                role: "user",
                content: ($prompt + "\n\nCurrent candidate.c:\n" + $source)
            }
        ]
    }' > "$request_path"

if ! "$curl_executable" \
    --silent \
    --show-error \
    --fail \
    --max-time "$timeout" \
    --retry 2 \
    --retry-delay 2 \
    --retry-max-time 120 \
    --header 'Content-Type: application/json' \
    --data-binary "@$request_path" \
    "$ollama_url/api/chat" > "$raw_response_path"; then
    echo "Ollama generation failed for model $model at $ollama_url" >&2
    exit 70
fi

if "$jq_executable" -er \
    '.message.content | fromjson | .source | select(type == "string" and length > 0)' \
    "$raw_response_path" > "$candidate_temporary" 2>/dev/null; then
    "$jq_executable" -er \
        '.message.content | fromjson | .summary // "Ollama updated candidate.c"' \
        "$raw_response_path" > "$response_path"
else
    "$jq_executable" -er '.message.content | select(type == "string" and length > 0)' \
        "$raw_response_path" > "$content_path" || {
        echo "Ollama returned no message content" >&2
        exit 65
    }
    if /usr/bin/awk '
        BEGIN { inside = 0; found = 0 }
        /^```/ {
            if (!inside) { inside = 1; found = 1; next }
            inside = 0
            exit
        }
        inside { print }
        END { if (!found || inside) exit 1 }
    ' "$content_path" > "$candidate_temporary"; then
        printf '%s\n' 'Ollama returned fenced source; extracted the complete candidate.c.' > "$response_path"
    elif /usr/bin/grep -q 'morph_app_entry' "$content_path" &&
        /usr/bin/grep -q '#include' "$content_path"; then
        /bin/cp "$content_path" "$candidate_temporary"
        printf '%s\n' 'Ollama returned raw source; accepted the complete candidate.c.' > "$response_path"
    else
        echo "Ollama returned content that was neither JSON nor complete C source" >&2
        exit 65
    fi
fi

if ! /usr/bin/grep -q 'morph_app_entry' "$candidate_temporary"; then
    echo "Ollama candidate is missing morph_app_entry" >&2
    exit 65
fi
/bin/mv "$candidate_temporary" "$candidate_path"

: "$diagnostics_path"
