#!/bin/sh
set -eu

if [ "$#" -ne 4 ]; then
    echo "usage: morpheus-codex-agent RUN_DIRECTORY PROMPT_PATH DIAGNOSTICS_PATH RESPONSE_PATH" >&2
    exit 64
fi

workspace=$1
prompt_path=$2
diagnostics_path=$3
response_path=$4
codex_executable=${MORPHEUS_CODEX_EXECUTABLE:-/Applications/ChatGPT.app/Contents/Resources/codex}

if [ ! -x "$codex_executable" ]; then
    echo "Codex CLI is not available at $codex_executable" >&2
    exit 127
fi

if [ ! -d "$workspace" ] || [ ! -f "$prompt_path" ]; then
    echo "Codex run directory or prompt is unavailable" >&2
    exit 66
fi

# Codex itself retains access to CODEX_HOME for authentication, while its
# model-generated commands receive only the minimal platform files plus this
# run directory. The run tree is read-only except for candidate.c. Morpheus
# writes the final response through Codex's parent process and validates every
# provider artifact after the process exits.
filesystem_profile='{":minimal"="read",":workspace_roots"={"."="read","candidate.c"="write"}}'

/bin/cat "$prompt_path" | "$codex_executable" \
    --ask-for-approval never \
    --strict-config \
    --disable apps \
    --disable hooks \
    --disable in_app_browser \
    --disable multi_agent \
    --disable plugin_sharing \
    --disable plugins \
    --disable remote_plugin \
    --disable skill_mcp_dependency_install \
    --disable skill_search \
    -c 'default_permissions="morpheus-agent"' \
    -c "permissions.morpheus-agent.filesystem=$filesystem_profile" \
    -c 'permissions.morpheus-agent.network.enabled=false' \
    -c 'shell_environment_policy.inherit="none"' \
    -c 'shell_environment_policy.set={PATH="/usr/bin:/bin:/usr/sbin:/sbin"}' \
    -c 'web_search="disabled"' \
    exec \
    --ephemeral \
    --ignore-user-config \
    --ignore-rules \
    --skip-git-repo-check \
    --color never \
    -C "$workspace" \
    --output-last-message "$response_path" \
    -

: "$diagnostics_path"
