#!/bin/sh
set -eu

workspace=$1
prompt_path=$2
diagnostics_path=$3
response_path=$4
codex_executable=${MORPHEUS_CODEX_EXECUTABLE:-/Applications/ChatGPT.app/Contents/Resources/codex}

if [ ! -x "$codex_executable" ]; then
    echo "Codex CLI is not available at $codex_executable" >&2
    exit 127
fi

# Anchor Codex repository discovery at this isolated run directory. The outer
# macOS sandbox prevents agent shell commands from traversing the user's home
# directory (including Photos, iCloud Drive, Desktop, and Documents).
/usr/bin/git -C "$workspace" init -q
privacy_profile='(version 1) (allow default) (deny file-read* (subpath "/Users"))'

/bin/cat "$prompt_path" | /usr/bin/sandbox-exec -p "$privacy_profile" "$codex_executable" \
    --ask-for-approval never \
    exec \
    --ephemeral \
    --ignore-user-config \
    --ignore-rules \
    --sandbox workspace-write \
    --skip-git-repo-check \
    --color never \
    -C "$workspace" \
    --output-last-message "$response_path" \
    -

: "$diagnostics_path"
