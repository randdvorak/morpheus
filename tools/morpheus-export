#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
source_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
output_path=${1:-"$source_root/build/exports/MorpheusFrozen.app"}
case "$output_path" in
    /*) ;;
    *) output_path="$source_root/build/exports/$output_path" ;;
esac
if [ "$#" -ge 2 ]; then
    source_path=$2
elif [ -f "$source_root/projects/.active-project" ]; then
    active_project=$(sed -n '1p' "$source_root/projects/.active-project")
    source_path="$source_root/projects/$active_project/app.c"
else
    source_path="$source_root/generated/app.c"
fi
assets_path=$(dirname -- "$source_path")/assets
app_name=${MORPHEUS_EXPORT_NAME:-"Morpheus App"}
bundle_id=${MORPHEUS_EXPORT_BUNDLE_ID:-"dev.morpheus.exported"}
app_version=${MORPHEUS_EXPORT_VERSION:-"1.0.0"}
export_build="$source_root/build/frozen-export"
cmake_command=${MORPHEUS_CMAKE_COMMAND:-}

if [ -n "$cmake_command" ]; then
    case "$cmake_command" in
        */*) [ -x "$cmake_command" ] || cmake_command= ;;
        *) cmake_command=$(command -v "$cmake_command" 2>/dev/null || true) ;;
    esac
fi
if [ -z "$cmake_command" ]; then
    cmake_command=$(command -v cmake 2>/dev/null || true)
fi
if [ -z "$cmake_command" ]; then
    for candidate in \
        /opt/homebrew/bin/cmake \
        /usr/local/bin/cmake \
        /Applications/CMake.app/Contents/bin/cmake
    do
        if [ -x "$candidate" ]; then
            cmake_command=$candidate
            break
        fi
    done
fi
if [ -z "$cmake_command" ]; then
    echo "CMake executable not found; set MORPHEUS_CMAKE_COMMAND" >&2
    exit 127
fi

if [ ! -f "$source_path" ]; then
    echo "Accepted source does not exist: $source_path" >&2
    exit 2
fi
if [ -e "$output_path" ]; then
    echo "Refusing to overwrite existing export: $output_path" >&2
    exit 3
fi

"$cmake_command" -S "$source_root" -B "$export_build" \
    -DBUILD_TESTING=OFF \
    -DMORPHEUS_FROZEN_SOURCE="$source_path" \
    -DMORPHEUS_EXPORT_ASSETS="$assets_path" \
    -DMORPHEUS_EXPORT_APP_NAME="$app_name" \
    -DMORPHEUS_EXPORT_BUNDLE_ID="$bundle_id" \
    -DMORPHEUS_EXPORT_APP_VERSION="$app_version"
"$cmake_command" --build "$export_build" --target morpheus_frozen --parallel

mkdir -p "$(dirname -- "$output_path")"
/usr/bin/ditto "$export_build/MorpheusFrozen.app" "$output_path"
/usr/bin/codesign --force --deep --sign - --options runtime "$output_path"
/usr/bin/codesign --verify --deep --strict "$output_path"

echo "$output_path"
