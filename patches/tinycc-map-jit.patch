 {
     Section *s;
     unsigned offset, length, align, i, k, f;
@@ -354,6 +393,10 @@ redo:
         return -1;
     if (copy == 3)
         return 0;
+#ifdef CONFIG_RUNMEM_MAP_JIT
+    if (copy == 2)
+        tcc_jit_write_protect(1);
+#endif
 
     for (k = 0; k < 3; ++k) { /* 0:rx, 1:ro, 2:rw sections */
         n = 0; addr = 0;
@@ -376,8 +419,10 @@ redo:
                     printf("%d: %-16s %p  len %05x  align %04x\n",
                         k, s->name, (void*)s->sh_addr, length, s->sh_addralign);
                 ptr = (void*)s->sh_addr;
+#ifndef CONFIG_RUNMEM_MAP_JIT
                 if (k == 0)
                     ptr = (void*)(s->sh_addr + ptr_diff);
+#endif
                 if (NULL == s->data || s->sh_type == SHT_NOBITS)
                     memset(ptr, 0, length);
                 else
@@ -412,11 +457,15 @@ redo:
                 continue;
 #endif
             f = k;
+#ifdef CONFIG_RUNMEM_MAP_JIT
+            continue;
+#else
             if (f >= CONFIG_RUNMEM_RO) {
                 if (f != 0)
                     continue;
                 f = 3; /* change only SHF_EXECINSTR to rwx */
             }
+#endif
             n = PAGEALIGN(n);
             if (s1->verbose == 2) {
                 printf("protect         %3s %p  len %05x\n",
@@ -427,7 +476,9 @@ redo:
 #ifdef _WIN32
                     "VirtualProtect failed");
 #else
-                    "mprotect failed (did you mean to configure --with-selinux?)");
+                    "mprotect failed for mode %u: %s",
+                    f,
+                    strerror(errno));
 #endif
         }
     }
